# Backend environment
# Copy this file to backend/.env and fill in the values you actually use.

# Database
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/eval_atlas
DATABASE_READ_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_REGION=
SUPABASE_USE_POOLER=false
SUPABASE_DB_NAME=postgres

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_MAX=120
CORS_ORIGIN=http://localhost:5173
MAX_EVAL_FILE_BYTES=5242880

# Optional auth for all /api routes
API_TOKEN=

# Optional local providers
AGENT_URL=http://localhost:3001
OLLAMA_URL=http://localhost:11434

# Cloud provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=

# Leave enabled for local smoke testing without external providers
MOCK_ENABLED=true
