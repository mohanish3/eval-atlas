POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=eval_atlas
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:change-me@localhost:5432/eval_atlas
DATABASE_READ_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=eval_atlas
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me
DATABASE_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_REGION=
SUPABASE_USE_POOLER=false
SUPABASE_DB_NAME=postgres

# Database URL integration samples
# Supabase direct:
# SUPABASE_PROJECT_REF=[YOUR-PROJECT-REF]
# SUPABASE_DB_PASSWORD=[YOUR-DATABASE-PASSWORD]
# SUPABASE_USE_POOLER=false
# Supabase transaction pooler:
# SUPABASE_PROJECT_REF=[YOUR-PROJECT-REF]
# SUPABASE_DB_PASSWORD=[YOUR-DATABASE-PASSWORD]
# SUPABASE_REGION=[YOUR-REGION]
# SUPABASE_USE_POOLER=true
# External Postgres:
# DATABASE_URL=postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DATABASE]?sslmode=require
# Separate host/user/password fields:
# DATABASE_HOST=[HOST]
# DATABASE_PORT=5432
# DATABASE_NAME=[DATABASE]
# DATABASE_USER=[USER]
# DATABASE_PASSWORD=[PASSWORD]
# DATABASE_SSL=true
# Optional read replica used for read-only queries:
# DATABASE_READ_URL=postgresql://[USER]:[PASSWORD]@[READ-HOST]:5432/[DATABASE]?sslmode=require

# Optional API auth for the backend
API_TOKEN=replace-with-a-shared-api-token

# Model provider API keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=gsk_your_groq_api_key
MISTRAL_API_KEY=your-mistral-api-key
COHERE_API_KEY=your-cohere-api-key
TOGETHER_API_KEY=your-together-api-key

# Optional local/mock model settings
MOCK_ENABLED=false
OLLAMA_URL=http://localhost:11434
AGENT_URL=http://localhost:3001
